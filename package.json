{
  "name": "slime",
  "version": "0.1.0",
  "description": "Self-evolving software powered by AI",
  "author": "hexueyuan",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "electron-vite dev --watch",
    "build": "pnpm run typecheck && electron-vite build",
    "build:unpack": "pnpm run build && electron-builder --dir",
    "build:mac": "pnpm run build && electron-builder --mac",
    "build:mac:arm64": "pnpm run build && electron-builder --mac --arm64",
    "build:mac:x64": "pnpm run build && electron-builder --mac --x64",
    "start": "electron-vite preview",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.app.json",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "postinstall": "electron-builder install-app-deps && simple-git-hooks"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/openai": "^3.0.53",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@pinia/colada": "^1.2.0",
    "@tailwindcss/typography": "^0.5.19",
    "ai": "^6.0.168",
    "markstream-vue": "0.0.13-beta.4",
    "pinia": "^3.0.4",
    "vue": "^3.5.31"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@iconify-json/lucide": "^1.2.99",
    "@iconify/vue": "^5.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^39.8.5",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.1",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.4.0",
    "lucide-vue-next": "^0.544.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "reka-ui": "^2.9.2",
    "simple-git-hooks": "^2.13.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vite-svg-loader": "^5.1.1",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.8"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "commit-msg": "node scripts/verify-commit.js \"$1\""
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.11.0"
  },
  "packageManager": "pnpm@10.13.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild",
      "simple-git-hooks"
    ]
  }
}
